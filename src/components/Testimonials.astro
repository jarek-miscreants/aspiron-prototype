---
import { Image } from "astro:assets";
import nightDragonLogo from "../assets/aspiron/nightdragon-logo.png";
import avatar from "../assets/aspiron/testimonial-avatar.png";
import arrowLeft from "../assets/aspiron/arrow-left.png";
import arrowRight from "../assets/aspiron/arrow-right.png";
import pagination from "../assets/aspiron/pagination.png";

// Testimonials horizontal scroller — 4+ NightDragon-style cards
const testimonials = Array.from({ length: 4 }, () => ({
  quote:
    "As a venture capital firm, we understand that great talent drives the success of our portfolio companies. That's why we're proud to partner with Aspiron Search, helping our companies access top executives and candidates to fuel their growth and achieve new levels of success.",
  name: "Amy De Salvatore",
  company: "NightDragon",
}));
---

<section class="relative py-[180px] pl-[120px]">
  <div class="flex flex-col gap-12">
    <!-- Slider track -->
    <div class="-mx-[120px] px-[120px]">
      <div class="flex gap-6 overflow-x-auto pb-2 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
        {
          testimonials.map((t, i) => (
            <article
              class:list={[
                "flex w-[480px] shrink-0 flex-col gap-10 rounded-card px-8 py-10",
                i === 0 ? "bg-cream" : "border border-white bg-transparent",
              ]}
            >
              <Image
                src={nightDragonLogo}
                alt="NightDragon"
                width={300}
                class="h-[105px] w-[150px] object-contain object-left"
              />
              <div class="flex flex-col gap-[30px]">
                <p class="font-body text-[22px] leading-[1.4]">{t.quote}</p>
                <div class="flex items-center gap-[30px]">
                  <Image
                    src={avatar}
                    alt={t.name}
                    width={300}
                    height={300}
                    class="h-[149px] w-[149px] rounded-avatar object-cover"
                  />
                  <div class="flex flex-1 flex-col items-end gap-3 text-right">
                    <p class="font-body text-[22px] leading-[1.4]">{t.name}</p>
                    <p class="font-mono text-[18px] uppercase">{t.company}</p>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Pagination + arrows -->
    <div class="flex items-center justify-center gap-6">
      <button
        type="button"
        aria-label="Previous testimonial"
        class="grid h-12 w-12 place-items-center rounded-pill border border-line bg-transparent transition hover:border-black"
      >
        <Image src={arrowLeft} alt="" width={32} class="h-4 w-4 -scale-x-100" />
      </button>
      <Image src={pagination} alt="" width={220} class="h-3.5 w-[110px]" />
      <button
        type="button"
        aria-label="Next testimonial"
        class="grid h-12 w-12 place-items-center rounded-pill bg-black transition hover:opacity-90"
      >
        <Image src={arrowRight} alt="" width={32} class="h-4 w-4" />
      </button>
    </div>
  </div>
</section>
