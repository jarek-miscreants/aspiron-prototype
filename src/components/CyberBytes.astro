---
import { Image } from "astro:assets";
import cyberBytesLogo from "../assets/aspiron/cyberbytes-logo.png";
---

<section class="container-page mt-6">
  <div class="flex flex-col items-center gap-12 rounded-card bg-black px-8 py-10 text-white">
    <div class="flex flex-col items-center gap-10">
      <Image
        src={cyberBytesLogo}
        alt="CyberBytes"
        width={850}
        class="h-[42px] w-[421px] object-contain"
      />
      <div class="flex flex-col items-center gap-6 text-center">
        <p class="h5 text-[#f7f8f3]">Showcasing Cybersecurity.</p>
        <p class="max-w-[794px] font-body text-[20px] leading-[1.4] text-white/75">
          CyberBytes is our content and community channel that showcases
          conversations with the founders, VCs, and other industry influencers
          shaping the ecosystem.
        </p>
      </div>
    </div>
    <a
      href="#cyberbytes"
      class="inline-flex items-center justify-center gap-2.5 rounded-pill border border-bg bg-black px-12 py-3 font-mono text-[18px] uppercase text-cta-yellow transition hover:bg-white/5"
    >
      Listen In
    </a>
  </div>
</section>
