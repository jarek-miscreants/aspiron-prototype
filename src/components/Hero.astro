---
import { Image } from "astro:assets";
import heroBg from "../assets/aspiron/hero-bg.png";
import cynet from "../assets/aspiron/cynet.png";
import qradar from "../assets/aspiron/qradar.png";
import qradar2 from "../assets/aspiron/qradar-2.png";
import cynet2 from "../assets/aspiron/cynet-2.png";

const trustLogos = [
  { name: "cynet", src: cynet },
  { name: "qradar", src: qradar },
  { name: "cynet", src: cynet2 },
  { name: "qradar", src: qradar2 },
  { name: "cynet", src: cynet },
  { name: "qradar", src: qradar },
];
---

<section class="relative overflow-hidden pt-[400px] pb-20">
  <!-- Chrome/gold liquid metal background — full viewport width, edge to edge -->
  <Image
    src={heroBg}
    alt=""
    widths={[1280, 1920, 2560]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-auto w-full select-none"
  />

  <div class="container-page relative flex flex-col items-center gap-20">
    <!-- Headline + subhead + CTA -->
    <div class="flex flex-col items-center gap-8 text-center">
      <h1 class="h1 max-w-[1053px]">
        The competitive advantage<br />
        to early-stage cybersecurity growth.
      </h1>
      <p class="max-w-[614px] font-body text-[22px] leading-[1.4]">
        Supporting founders and investors to build and scale category-defining
        cybersecurity companies.
      </p>
      <a href="#contact" class="btn-cta mt-2">CTA Primary</a>
    </div>

    <!-- Trust logo strip -->
    <div class="flex w-full max-w-[1488px] flex-wrap items-center justify-center gap-x-20 gap-y-6">
      {
        trustLogos.map((logo) => (
          <Image
            src={logo.src}
            alt={logo.name}
            width={260}
            class="h-8 w-auto object-contain"
          />
        ))
      }
    </div>
  </div>
</section>
