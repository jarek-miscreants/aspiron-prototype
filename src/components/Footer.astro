---
import { Image } from "astro:assets";
import footerLogo from "../assets/aspiron/footer-logo.png";
import socialIcon1 from "../assets/aspiron/social-icon-1.png";
import socialIcon2 from "../assets/aspiron/social-icon-2.png";

const linkColumns = [
  {
    title: "The Company",
    links: ["Why Aspiron?", "Cyberbytes", "Ventures", "Contact Us"],
  },
  {
    title: "Useful Links",
    links: ["Resources", "Vacancies", "Work For Us"],
  },
  {
    title: "Support",
    links: ["Privacy Policy", "Cookies Policy", "Terms & Conditions", "HTML Sitemap"],
  },
];
---

<footer class="container-page py-10">
  <div class="flex flex-col items-start gap-10 rounded-card bg-cream p-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 w-full gap-10  md:gap-6">
      <!-- Brand block -->
      <div class="flex w-full flex-col items-start gap-10 md:w-[394px]">
        <Image
          src={footerLogo}
          alt="Aspiron"
          width={500}
          class="h-auto w-[200px] max-w-full object-contain md:w-[251px]"
        />
        <div class="flex gap-2.5">
          <a
            href="#"
            class="grid h-14 w-14 place-items-center rounded-[42px] bg-black transition hover:opacity-80"
            aria-label="LinkedIn"
          >
            <Image src={socialIcon1} alt="" width={48} class="h-6 w-6" />
          </a>
          <a
            href="#"
            class="grid h-14 w-14 place-items-center rounded-[42px] bg-black transition hover:opacity-80"
            aria-label="X"
          >
            <Image src={socialIcon2} alt="" width={48} class="h-6 w-6" />
          </a>
        </div>
      </div>

      <!-- Right side: contacts + 3 link columns.
           Auto-fit grid wraps columns based on available space, no breakpoints. -->
      <div class="grid w-full flex-1 gap-10 [grid-template-columns:repeat(auto-fit,minmax(180px,1fr))]">
        <!-- Contact -->
        <div class="flex flex-col justify-center gap-10">
          <div class="flex flex-col gap-5">
            <p class="font-mono text-[18px] uppercase">North America</p>
            <p class="font-body text-[17px] opacity-75">+1 315 556 2555</p>
          </div>
          <div class="flex flex-col gap-5">
            <p class="font-mono text-[18px] uppercase">United Kingdom</p>
            <p class="font-body text-[17px] opacity-75">+44 20 4530 6936</p>
          </div>
        </div>

        <!-- Link columns -->
        {
          linkColumns.map((col) => (
            <div class="flex flex-col gap-5">
              <p class="h5">{col.title.toUpperCase()}</p>
              <ul class="flex flex-col gap-2.5">
                {col.links.map((link) => (
                  <li>
                    <a
                      href="#"
                      class="font-body text-[17px] leading-[1.4] opacity-75 transition hover:opacity-100"
                    >
                      {link}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <p class="font-mono text-[13px] uppercase opacity-80">
      Copyright © Aspiron Search Limited – All rights reserved
    </p>
  </div>
</footer>
